# ─── Auth ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_AUTH=true                          # Set to false to disable auth locally
NEXT_PUBLIC_APP_URL=http://localhost:3000      # This app's public URL (used in auth redirect)
NEXT_PUBLIC_AUTH_URL=https://your-auth-server  # External auth service URL

# ─── Azure Storage containers ─────────────────────────────────────────────────
AZURE_STORAGE_IMAGES_CONTAINER=generated-images
AZURE_STORAGE_VIDEOS_CONTAINER=generated-videos
AZURE_STORAGE_ASSETS_CONTAINER=assets

# ─── Backend ─────────────────────────────────────────────────────────────────
BACKEND_URL=http://localhost:4000
